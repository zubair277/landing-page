rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function isSuperAdmin() {
      return isSignedIn() && userRole(request.auth.uid) == "super_admin";
    }

    function isOwner(restaurantId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerUid == request.auth.uid;
    }

    function ownerForDoc(existingRestaurantId, incomingRestaurantId) {
      return isOwner(incomingRestaurantId != null ? incomingRestaurantId : existingRestaurantId);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    match /restaurants/{restaurantId} {
      allow read: if true;
      allow create: if isSignedIn() &&
        (request.resource.data.ownerUid == request.auth.uid || isSuperAdmin());
      allow update, delete: if isOwner(restaurantId) || isSuperAdmin();
    }

    match /dishes/{dishId} {
      allow read: if true;
      allow create: if ownerForDoc(null, request.resource.data.restaurantId) || isSuperAdmin();
      allow update: if ownerForDoc(resource.data.restaurantId, request.resource.data.restaurantId) || isSuperAdmin();
      allow delete: if ownerForDoc(resource.data.restaurantId, null) || isSuperAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if ownerForDoc(null, request.resource.data.restaurantId) || isSuperAdmin();
      allow update: if ownerForDoc(resource.data.restaurantId, request.resource.data.restaurantId) || isSuperAdmin();
      allow delete: if ownerForDoc(resource.data.restaurantId, null) || isSuperAdmin();
    }

    match /media/{mediaId} {
      allow read: if true;
      allow create: if ownerForDoc(null, request.resource.data.restaurantId) || isSuperAdmin();
      allow update: if ownerForDoc(resource.data.restaurantId, request.resource.data.restaurantId) || isSuperAdmin();
      allow delete: if ownerForDoc(resource.data.restaurantId, null) || isSuperAdmin();
    }
  }
}

