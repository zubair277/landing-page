rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    // Path convention used by app: restaurants/{restaurantId}/{filename}
    match /restaurants/{restaurantId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}

